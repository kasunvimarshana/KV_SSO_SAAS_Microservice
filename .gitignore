# Env files (keep examples, ignore actual)
.env
*.env

# Vendor directories
*/vendor/
*/node_modules/

# Laravel storage (keep directory, not contents)
*/storage/logs/*.log
*/storage/app/public
*/storage/framework/cache/data
*/storage/framework/sessions
*/storage/framework/views

# Bootstrap cache (runtime, not source)
*/bootstrap/cache/*.php

# PHPUnit caches
*/.phpunit.result.cache
*/.phpunit.cache/

# Docker volumes
.docker/

# IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store
Thumbs.db
